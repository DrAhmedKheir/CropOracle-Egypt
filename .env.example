# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# APSIM Next Gen
APSIM_EXE=C:/Program Files/APSIM2025.1.XXXX/bin/Models.exe
APSIM_TEMPLATE=apsim_templates/egypt_wheat_template.apsimx
OUTPUT_DIR=outputs

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=change_this_verify_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_access_token

# LLM provider; optional for prototype
OPENAI_API_KEY=your_openai_key
LLM_MODEL=gpt-4.1-mini

# Default Egypt settings
DEFAULT_LANGUAGE=en
DEFAULT_CROP=wheat
DEFAULT_GOVERNORATE=Kafr El-Sheikh
